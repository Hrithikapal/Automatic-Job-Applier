# Anthropic API Key — required for resume tailoring, cover letter, and field inference
ANTHROPIC_API_KEY=sk-ant-...

# Database — SQLite by default, swap to PostgreSQL for production
DATABASE_URL=sqlite:///./ai_job_applier.db

# Job site credentials (used by ATS sign-in nodes)
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword
GREENHOUSE_EMAIL=your@email.com
GREENHOUSE_PASSWORD=yourpassword
LEVER_EMAIL=your@email.com
LEVER_PASSWORD=yourpassword
WORKDAY_EMAIL=your@email.com
WORKDAY_PASSWORD=yourpassword

# HITL Settings
HITL_TIMEOUT_SECONDS=30

# LLM inference confidence threshold (0.0–1.0); below this triggers HITL
LLM_CONFIDENCE_THRESHOLD=0.7

# Browser settings
BROWSER_HEADLESS=false
